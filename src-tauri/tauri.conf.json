{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sito File Browser",
  "version": "0.2.0",
  "identifier": "com.sito8943.file-browser",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "macOSPrivateApi": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "File Browser",
        "label": "main",
        "width": 950,
        "minWidth": 950,
        "height": 600,
        "minHeight": 600,
        "center": true,
        "transparent": true,
        "decorations": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; media-src 'self' asset: https://asset.localhost; frame-src 'self' asset: https://asset.localhost; object-src 'self' asset: https://asset.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["**", "**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["icons/32x32.png"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
